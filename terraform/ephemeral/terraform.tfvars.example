# ══════════════════════════════════════════════════════════════
#  EXEMPLE DE VARIABLES — terraform/ephemeral/terraform.tfvars.example
#
#  Copier vers terraform.tfvars et renseigner les valeurs :
#    cp terraform.tfvars.example terraform.tfvars
# ══════════════════════════════════════════════════════════════

environment = "dev"

# Clé SSH publique pour accéder à l'EC2
# Générer : ssh-keygen -t ed25519 -C "todo-minikube" -f ~/.ssh/todo-minikube
# Puis copier le contenu de ~/.ssh/todo-minikube.pub :
ec2_ssh_public_key = "ssh-ed25519 AAAA... votre_cle_publique"

# Type d'instance (t2.micro = Free Tier)
ec2_instance_type = "t2.micro"
