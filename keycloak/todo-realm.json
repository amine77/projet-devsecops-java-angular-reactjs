{
  "realm": "todo",
  "enabled": true,
  "displayName": "Todo Enterprise",
  "displayNameHtml": "<b>Todo Enterprise</b>",
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,

  "roles": {
    "realm": [
      {
        "name": "GESTIONNAIRE",
        "description": "Gestionnaire — gère ses propres to-dos"
      },
      {
        "name": "MANAGER",
        "description": "Manager — valide/rejette les to-dos de son équipe"
      },
      {
        "name": "SUPER_ADMINISTRATEUR",
        "description": "Super Administrateur — accès global"
      }
    ]
  },

  "clients": [
    {
      "clientId": "todo-app",
      "name": "Todo App",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "rootUrl": "http://localhost:8080",
      "baseUrl": "/",
      "redirectUris": [
        "http://localhost:8080/*",
        "http://localhost:4200/*",
        "http://localhost:3000/*",
        "http://todo.local/*"
      ],
      "webOrigins": [
        "http://localhost:8080",
        "http://localhost:4200",
        "http://localhost:3000",
        "http://todo.local"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:4200/*##http://localhost:3000/*"
      },
      "protocolMappers": [
        {
          "name": "roles-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "teamId-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "teamId",
            "claim.name": "teamId",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "unitId-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "unitId",
            "claim.name": "unitId",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],

  "users": [
    {
      "username": "gestionnaire1",
      "email": "gestionnaire1@todo.local",
      "firstName": "Alice",
      "lastName": "Dupont",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "password", "temporary": false }],
      "realmRoles": ["GESTIONNAIRE"],
      "attributes": {
        "teamId": ["11111111-1111-1111-1111-111111111111"],
        "unitId": ["aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa"]
      }
    },
    {
      "username": "gestionnaire2",
      "email": "gestionnaire2@todo.local",
      "firstName": "Bob",
      "lastName": "Martin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "password", "temporary": false }],
      "realmRoles": ["GESTIONNAIRE"],
      "attributes": {
        "teamId": ["11111111-1111-1111-1111-111111111111"],
        "unitId": ["aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa"]
      }
    },
    {
      "username": "manager1",
      "email": "manager1@todo.local",
      "firstName": "Claire",
      "lastName": "Bernard",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "password", "temporary": false }],
      "realmRoles": ["MANAGER"],
      "attributes": {
        "teamId": ["11111111-1111-1111-1111-111111111111"],
        "unitId": ["aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa"]
      }
    },
    {
      "username": "superadmin",
      "email": "superadmin@todo.local",
      "firstName": "Super",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "password", "temporary": false }],
      "realmRoles": ["SUPER_ADMINISTRATEUR"]
    }
  ],

  "accessTokenLifespan": 300,
  "ssoSessionMaxLifespan": 36000
}
